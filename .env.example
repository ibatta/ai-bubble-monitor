# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ai_bubble

# API Keys (all free-tier except Claude)
FRED_API_KEY=your_fred_api_key_here
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here
NEWS_API_KEY=your_news_api_key_here_optional
# Claude API — used for filing extraction (W2, G2, G3) and C3 news classifier
# Get from: https://console.anthropic.com/
CLAUDE_API_KEY=your_anthropic_claude_api_key_here

# Admin Auth
ADMIN_TOKEN=change_this_to_a_long_random_secret
CENSUS_API_KEY=your_census_bureau_api_key_here

# Dashboard Protection Password (Optional)
# Leave empty or omit if you don't want password protection for the dashboard.
DASHBOARD_PASSWORD=your_optional_dashboard_protection_password


# Email Alerts (Gmail App Password recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
ALERT_TO=your_email@gmail.com

# Server
PORT=3001
NODE_ENV=development
